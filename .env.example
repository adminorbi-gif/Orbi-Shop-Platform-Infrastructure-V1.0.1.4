# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="REPLACE_WITH_YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="REPLACE_WITH_YOUR_APP_URL"

# ORBI Pay Gateway Live Integration
ORBI_PAY_GATEWAY_BASE_URL="https://pay.orbifinancial.com"
ORBI_SHOP_PAY_API_KEY="REPLACE_WITH_RESTRICTED_ORBI_SHOP_PAY_SERVICE_KEY"
ORBI_SHOP_PAY_WEBHOOK_URL="https://shop.orbifinancial.com/api/orbi-pay/webhooks"
ORBI_SHOP_PAY_WEBHOOK_SECRET="REPLACE_WITH_ORBI_SHOP_PAY_WEBHOOK_SECRET"
ORBI_SHOP_PAY_WEBHOOK_MAX_AGE_SECONDS=300
ORBI_CORE_BASE_URL="https://api.orbifinancial.com"
ORBI_CORE_APP_ID="orbi-shop"
ORBI_CORE_APP_ORIGIN="https://shop.orbifinancial.com"
ORBI_CORE_PAYSAFE_HOLD_MINUTES=1440

# Keycloak Auth Migration Target
ORBI_KEYCLOAK_ISSUER="https://auth.orbifinancial.com/realms/orbi"
ORBI_KEYCLOAK_CLIENT_ID="orbi-shop"

# Supabase Auth Configuration
VITE_SUPABASE_URL="REPLACE_WITH_YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="REPLACE_WITH_YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Database Encryption Key
# IMPORTANT: Must be exactly 32 keys/chars for aes-256
ENCRYPTION_KEY="REPLACE_WITH_A_32_CHAR_SECRET_KEY"

# Orbi Talk Gateway Configuration
ORBI_TALK_GATEWAY_URL="https://talk.orbifinancial.com"
ORBI_SHOP_TALK_API_KEY=
ORBI_SHOP_TALK_OWNER_UID=
ORBI_SHOP_TALK_OWNER_EMAIL="shop@orbifinancial.com"

# Cloudflare R2 Storage (S3 Compatible)
CLOUDFLARE_ACCOUNT_ID="80f852d*********8bfd528c00f43f7e"
CLOUDFLARE_ACCESS_KEY_ID="8bf1f1780*******c5751f6d158204"
CLOUDFLARE_SECRET_ACCESS_KEY="50c3a899f57b14********59146b6bde63cde071e41*****f924d6a5d"
CLOUDFLARE_BUCKET_NAME="orbishop-storage"
CLOUDFLARE_PUBLIC_URL_PREFIX="https://shop-store.orbifinancial.com"

# Google Maps API Key (Required for Maps, Places, and Routes)
